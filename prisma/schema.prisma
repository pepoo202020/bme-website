// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  name      String?
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model HeroSlide {
  id          Int      @id @default(autoincrement())
  image       String
  arabic_subtitle    String?
  english_subtitle    String?
  arabic_title       String?
  english_title       String?
  arabic_description String?
  english_description String?
  arabic_buttonText  String?
  english_buttonText  String?
  arabic_buttonLink  String?
  english_buttonLink  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Category {
  id           Int       @id @default(autoincrement())
  image        String
  arabic_name  String?
  english_name String?
  products     Product[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Product {
  id                  Int      @id @default(autoincrement())
  english_name        String
  arabic_name         String?
  price               Float?
  currency            String   @default("USD")
  discount            Float?
  image               String?
  images              String[]
  arabic_description  String?
  english_description String?
  sku                 String?
  stock               Int?     @default(0)
  rating              Float?   @default(0)
  reviews             Int?     @default(0)
  isFeatured          Boolean  @default(false)
  categoryId          Int
  category            Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  
  orderItems          OrderItem[]
  
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model CategorySection {
  id                  Int      @id @default(autoincrement())
  arabic_header       String?
  english_header      String?
  arabic_description  String?
  english_description String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model FeaturedProductsSection {
  id                  Int      @id @default(autoincrement())
  arabic_header       String?
  english_header      String?
  arabic_description  String?
  english_description String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model WhoWeAreSection {
  id                  Int               @id @default(autoincrement())
  arabic_header       String?
  english_header      String?
  arabic_description  String?
  english_description String?
  backgroundImage     String?
  contents            WhoWeAreContent[]
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
}

model WhoWeAreContent {
  id               Int             @id @default(autoincrement())
  icon             String?
  arabic_title     String?
  english_title    String?
  arabic_subtitle  String?
  english_subtitle String?
  sectionId        Int
  section          WhoWeAreSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
}

model GalleryImage {
  id           Int      @id @default(autoincrement())
  url          String
  alt          String?
  categoryId   Int?
  category     GalleryCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model GalleryPage {
  id                  Int      @id @default(autoincrement())
  arabic_header       String?
  english_header      String?
  arabic_description  String?
  english_description String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model GalleryCategory {
  id           Int      @id @default(autoincrement())
  arabic_name  String
  english_name String
  images       GalleryImage[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model GallerySectionConfig {
  id                  Int      @id @default(autoincrement())
  arabic_header       String?
  english_header      String?
  arabic_description  String?
  english_description String?
  selectedImageIds    Int[]
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model StatisticsSection {
  id                  Int              @id @default(autoincrement())
  arabic_header       String?
  english_header      String?
  arabic_description  String?
  english_description String?
  items               StatisticsItem[]
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
}

model StatisticsItem {
  id              Int               @id @default(autoincrement())
  color           String            @default("#3b82f6")
  percentage      Int
  arabic_title    String?
  english_title   String?
  sectionId       Int
  section         StatisticsSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
}

model CompanyInfo {
  id                  Int      @id @default(autoincrement())
  email               String?
  phone               String?
  arabic_address      String?
  english_address     String?
  arabic_workingDays  String?
  english_workingDays String?
  
  // Social Media Links
  facebook            String?
  twitter             String? // X
  instagram           String?
  linkedin            String?
  youtube             String?
  
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

// ── About Us Page ──

model AboutMainHeader {
  id                  Int      @id @default(autoincrement())
  arabic_header       String?
  english_header      String?
  arabic_description  String?
  english_description String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model AboutVisionSection {
  id        Int                @id @default(autoincrement())
  items     AboutVisionItem[]
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
}

model AboutVisionItem {
  id                  Int                @id @default(autoincrement())
  icon                String?
  arabic_title        String?
  english_title       String?
  arabic_description  String?
  english_description String?
  sectionId           Int
  section             AboutVisionSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
}

model AboutTeamSection {
  id                  Int               @id @default(autoincrement())
  arabic_header       String?
  english_header      String?
  arabic_description  String?
  english_description String?
  items               AboutTeamMember[]
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
}

model AboutTeamMember {
  id             Int              @id @default(autoincrement())
  image          String?
  arabic_name    String?
  english_name   String?
  arabic_title   String?
  english_title  String?
  sectionId      Int
  section        AboutTeamSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
}

model AboutHeroesSection {
  id                  Int              @id @default(autoincrement())
  arabic_header       String?
  english_header      String?
  arabic_description  String?
  english_description String?
  items               AboutHeroItem[]
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
}

model AboutHeroItem {
  id             Int                @id @default(autoincrement())
  image          String?
  arabic_name    String?
  english_name   String?
  arabic_title   String?
  english_title  String?
  sectionId      Int
  section        AboutHeroesSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
}

// ── Contact Us Page ──

model ContactUsSection {
  id                  Int      @id @default(autoincrement())
  arabic_header       String?
  english_header      String?
  arabic_description  String?
  english_description String?
  latitude            String?
  longitude           String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model ContactMessage {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  subject   String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ── Store & Products Pages ──

model StorePage {
  id                  Int      @id @default(autoincrement())
  arabic_header       String?
  english_header      String?
  arabic_description  String?
  english_description String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model ProductsPage {
  id                  Int      @id @default(autoincrement())
  arabic_header       String?
  english_header      String?
  arabic_description  String?
  english_description String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

// ── Orders & Checkout ──

model Order {
  id              String      @id @default(uuid())
  customerName    String
  customerEmail   String
  customerPhone   String
  shippingAddress String
  city            String
  
  paymentMethod   String      // "COD" or "MANUAL"
  paymentStatus   String      @default("PENDING") // PENDING, COMPLETED, FAILED
  orderStatus     String      @default("PENDING") // PENDING, PROCESSING, SHIPPED, DELIVERED, CANCELLED
  
  subtotal        Float
  shippingFee     Float
  total           Float
  currency        String      @default("USD") // Currency used at checkout
  
  receiptImage    String?     // For manual transfer proof
  notes           String?
  
  items           OrderItem[]
  
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model OrderItem {
  id          String   @id @default(uuid())
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  productId   Int
  product     Product  @relation(fields: [productId], references: [id], onDelete: Restrict)
  
  productName String   // Snapshot of the name at purchase time
  quantity    Int
  unitPrice   Float    // Snapshot of the price at purchase time
  totalPrice  Float    // quantity * unitPrice
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
